{
  "expo": {
    "name": "Safarihills",
    "slug": "safarihill",
    "version": "2.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/SafariLogo.png",
    "scheme": "safarihills",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/safarihills-splash-4.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.safarihills.app",
      "associatedDomains": [
        "applinks:safarihills.app",
        "applinks:www.safarihills.app",
        "applinks:safarihills.app",
        "applinks:www.safarihills.app"
      ],
      "buildNumber": "1",
      "icon": "./assets/images/SafariLogo.png",
      "googleServicesFile": "./GoogleService-Info.plist",
      "notification": {
        "icon": "./assets/images/SafariLogo.png",
        "color": "#fff"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.safarihills.listings",
      "googleServicesFile": "./google-services.json",
      "versionCode": 12,
      "icon": "./assets/images/SafariLogo.png",
      "notification": {
        "icon": "./assets/images/android-notification-icon.png",
        "color": "#1d4ed8"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-adaptive-foreground.png",
        "backgroundColor": "#004AAD"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "safarihills.app",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "www.safarihills.app",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "splash": {
        "image": "./assets/images/safari-splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/safari-splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-notification-icon.png",
          "color": "#1d4ed8"
        }
      ],
      "@react-native-firebase/app",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "buildReactNativeFromSource": true,
            "forceStaticLinking": [
              "RNFBApp",
              "RNFBAnalytics"
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8b4ca1cb-15af-4f50-9746-463ed43190e9"
      }
    },
    "owner": "adiim"
  }
}
